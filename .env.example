MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=testai

DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

ALERT_WEBHOOK_URL=https://your-webhook-url.com/alert

REDIS_URL=redis://localhost:6379/0

HTTP_TIMEOUT=10.0
HTTP_MAX_CONNECTIONS=100

LOG_LEVEL=INFO
ENVIRONMENT=production

GOVERNANCE_DB_PATH=./data/governance.sqlite
MAX_CONCURRENT_LLM_CALLS=5
APPROVAL_EXPIRY_MINUTES=30
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# === 数据库配置 ===
# 生产环境使用 PostgreSQL: postgresql://user:pass@localhost:5432/testai
# 开发环境默认使用 SQLite
DATABASE_URL=sqlite:///data/testai.db
SQLITE_PATH=data/testai.db

# === 安全配置 ===
# JWT 密钥 - 生产环境必须设置，至少32字节
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-at-least-32-bytes-long-here
JWT_SECRET_KEY=your-secret-key-at-least-32-bytes-long-here

# Token 过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 默认用户密码 - 生产环境必须修改
DEFAULT_USER_PASSWORD=ChangeMeInProduction123

# 邮件通知配置
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 钉钉通知
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-secret

# 飞书通知
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
  "defect_cases": {
    "defect_division_by_zero": {
      "defect_id": "defect_001",
      "description": "除零错误缺陷",
      "severity": "high",
      "location": "vulnerable_app.py:86-93",
      "expected_diagnosis": "除法运算中除数为零导致异常",
      "expected_fix": "在除法前添加除数非零检查",
      "test_input": {"a": 10, "b": 0},
      "expected_output": "错误: 除数不能为零",
      "convergence_criteria": ["不再抛出异常", "返回正确的错误提示"]
    },
    "defect_infinite_loop": {
      "defect_id": "defect_002",
      "description": "无限循环缺陷",
      "severity": "critical",
      "location": "vulnerable_app.py:130-132",
      "expected_diagnosis": "缺少循环终止条件",
      "expected_fix": "添加最大迭代次数限制或终止条件",
      "test_input": {},
      "expected_output": "循环已终止",
      "convergence_criteria": ["函数能够正常返回", "执行时间在合理范围内"]
    },
    "defect_recursive_fibonacci": {
      "defect_id": "defect_003",
      "description": "递归斐波那契性能缺陷",
      "severity": "medium",
      "location": "vulnerable_app.py:70-75",
      "expected_diagnosis": "递归实现导致指数级时间复杂度",
      "expected_fix": "改用迭代实现或添加缓存",
      "test_input": {"n": 30},
      "expected_output": 832040,
      "convergence_criteria": ["执行时间 < 1秒", "结果正确"]
    },
    "defect_hardcoded_secret": {
      "defect_id": "defect_004",
      "description": "硬编码密钥缺陷",
      "severity": "critical",
      "location": "vulnerable_app.py:9",
      "expected_diagnosis": "密钥硬编码在源代码中",
      "expected_fix": "通过环境变量或密钥管理服务注入",
      "test_input": {},
      "expected_output": "密钥已安全配置",
      "convergence_criteria": ["源代码中不再包含硬编码密钥"]

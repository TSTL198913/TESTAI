  "baselines": {
    "api_test_httpbin_post": {
      "test_id": "golden_001",
      "description": "HTTP POST请求测试基线",
      "protocol": "http",
      "method": "POST",
      "url": "https://httpbin.org/anything",
      "expected_status": 200,
      "expected_headers": ["Content-Type"],
      "expected_body_patterns": ["json", "args"],
      "success_criteria": ["status_code == 200", "body contains 'json'"]
    },
    "api_test_httpbin_get": {
      "test_id": "golden_002",
